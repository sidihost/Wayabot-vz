# =============================================================================
# WAYA TELEGRAM BOT - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your values
# 
# cp .env.example .env
# nano .env
# =============================================================================

# =============================================================================
# REQUIRED - These are needed for the bot to work
# =============================================================================

# Telegram Bot Token (from @BotFather)
# 1. Open Telegram and search for @BotFather
# 2. Send /newbot command
# 3. Follow the instructions to create your bot
# 4. Copy the token (looks like: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Groq API Key (for AI responses)
# 1. Go to https://console.groq.com
# 2. Sign up or log in
# 3. Navigate to API Keys
# 4. Create a new API key (starts with "gsk_")
# NOTE: 403 errors mean the key is invalid/expired - regenerate it!
GROQ_API_KEY=your_groq_api_key_here

# Groq Model (optional - defaults to llama-3.3-70b-versatile)
# Options: llama-3.3-70b-versatile, llama-3.1-8b-instant
GROQ_MODEL=llama-3.3-70b-versatile

# PostgreSQL Database URL
# Format: postgresql://user:password@host:port/database
# For Docker: postgresql://waya:wayabot123@postgres:5432/wayabot
# For external DB: postgresql://user:pass@your-db-host:5432/wayabot
DATABASE_URL=postgresql://waya:wayabot123@postgres:5432/wayabot

# =============================================================================
# DATABASE SETTINGS (for docker-compose)
# =============================================================================

DB_USER=waya
DB_PASSWORD=wayabot123
DB_NAME=wayabot

# =============================================================================
# OPTIONAL - Enhanced features
# =============================================================================

# ElevenLabs API Key (for voice replies)
# Get from: https://elevenlabs.io
# Features: Text-to-speech, voice replies, multiple voices
ELEVENLABS_API_KEY=

# Hume AI API Key (for emotion detection)
# Get from: https://hume.ai
# Features: Emotion analysis, empathic responses
HUME_API_KEY=

# =============================================================================
# DEPLOYMENT SETTINGS
# =============================================================================

# Your domain or IP address (for webhook)
BOT_DOMAIN=waya.qzz.io

# =============================================================================
# BOT CUSTOMIZATION
# =============================================================================

# Bot display name
BOT_NAME=Waya

# Default AI temperature (0.0 - 1.0, higher = more creative)
AI_TEMPERATURE=0.7

# Max conversation history to keep in context
MAX_CONVERSATION_HISTORY=20
